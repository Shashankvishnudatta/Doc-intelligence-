# Backend environment example
# Copy this file to .env and fill required values.

# App
APP_NAME=Document Intelligence + Agentic RAG
ENVIRONMENT=development

# Database
SQLITE_DB_PATH=data/sqlite/app.db

# Local storage
UPLOAD_DIR=data/uploads
PAGE_IMAGE_DIR=data/pages
MAX_UPLOAD_SIZE_MB=20

# Chroma / vector store
CHROMA_DIR=data/chroma
CHROMA_PATH=data/chroma
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION_NAME=document_chunks

# Embeddings
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# RAG provider modes:
# fallback = deterministic local grounded answer
# hf = Hugging Face LLM answer
# hybrid = fast deterministic for direct questions, HF for complex questions
# gemini = Gemini answer if API access works
RAG_PROVIDER=hybrid

# Hugging Face Inference Providers
HF_TOKEN=
HF_MODEL=Qwen/Qwen2.5-7B-Instruct:fastest
HF_TIMEOUT_SECONDS=5

# Gemini optional
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash
RAG_USE_GEMINI=false
RAG_USE_GEMINI_VISION=true
GEMINI_TIMEOUT_SECONDS=30

# Frontend / CORS
FRONTEND_ORIGIN=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
